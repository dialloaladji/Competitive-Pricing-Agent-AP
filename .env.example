# Environment
ENVIRONMENT=development
MOCK_MODE=false
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pricing_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM Provider (Groq via OpenAI-compatible endpoint)
LLM_PROVIDER=llamacpp
LLAMA_CPP_BASE_URL=https://api.groq.com/openai/v1
LLAMA_CPP_MODEL=llama-3.1-8b-instant
LLAMA_CPP_API_KEY=gsk_your_key_here
LLM_MAX_TOKENS=512

# External APIs
TAVILY_API_KEY=tvly-your-key-here
SERPAPI_API_KEY=your-serpapi-key-here
WEB_SEARCH_PRIMARY=tavily
WEB_SEARCH_FALLBACK=serpapi
WEB_SEARCH_MAX_RESULTS=3

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Scheduling (default intervals in minutes)
PRICE_TRACK_INTERVAL_MINUTES=60
ALERT_CHECK_INTERVAL_MINUTES=15

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Cache
CACHE_TTL_SECONDS=300
